# Kalshi API credentials
# Copy this file to .env and fill in your values

# Your Kalshi API Key ID (found in Account Settings > API)
KALSHI_API_KEY_ID=your_api_key_id_here

# RSA private key contents in PEM format (the full key, not a file path)
# Generate with: openssl genrsa -out kalshi_private_key.pem 2048
# Then upload the public key to Kalshi's API settings
# Paste the key on one line using \n for newlines, or use a multiline value
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Set to true to simulate orders without real API calls
DRY_RUN=true
